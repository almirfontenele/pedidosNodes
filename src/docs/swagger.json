{
  "openapi": "3.0.0",
  "info": {
    "title": "Orders-Service API",
    "version": "1.0.0",
    "description": "API para gestão e orquestração de pedidos (Orders-Service)"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "paths": {
    "/orders": {
      "post": {
        "summary": "Cria um novo pedido",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrder"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pedido criado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Erro na requisição (ex: estoque insuficiente)"
          }
        }
      },
      "get": {
        "summary": "Lista pedidos com filtros",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "customerId",
            "in": "query",
            "schema": { "type": "string" },
            "description": "ID do cliente"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["PENDENTE", "PAGO", "ENVIADO", "CANCELADO"]
            },
            "description": "Status do pedido"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de pedidos retornada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Order"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/orders/{id}/status": {
      "patch": {
        "summary": "Atualiza o status de um pedido",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["PAGO", "ENVIADO", "CANCELADO"]
                  }
                },
                "required": ["status"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status atualizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Transição de status inválida ou erro"
          }
        }
      }
    },
    "/orders/{id}": {
      "delete": {
        "summary": "Cancela um pedido",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": {
            "description": "Pedido cancelado com sucesso"
          },
          "400": {
            "description": "Pedido não pode ser cancelado (ex: já enviado)"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OrderItem": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "quantity": { "type": "integer" },
          "unitPrice": { "type": "number" }
        }
      },
      "CreateOrder": {
        "type": "object",
        "properties": {
          "customerId": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OrderItem" }
          },
          "freight": { "type": "number" }
        },
        "required": ["customerId", "items", "freight"]
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "customerId": { "type": "string" },
          "status": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OrderItem" }
          },
          "freight": { "type": "number" },
          "total": { "type": "number" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
